# Copy this file to .env.local and fill in your Firebase project's web config
# (Project settings -> General -> Your apps -> SDK setup and configuration)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# This must be your Realtime Database URL, e.g.
# https://bustrackingsystem-24baf-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://bustrackingsystem-24baf-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bustrackingsystem-24baf
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
